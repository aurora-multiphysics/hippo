[Tests]
    [foam_bc_diffusion_flux_pp]
        [setup]
            type = RunCommand
            command = 'bash -c "foamCleanCase -case foam && blockMesh -case foam"'
        []
        [diffusivity_err]
            type = RunException
            input = main.i
            prereq = foam_bc_diffusion_flux_pp/setup
            expect_err = "Diffusivity 'kappa1' not a Foam volScalarField"
            cli_args = 'FoamBCs/T_flux/diffusivity=kappa1'
        []
        [run]
            type = RunApp
            input = main.i
            prereq = foam_bc_diffusion_flux_pp/setup
        []
        [verify]
            type = PythonUnitTest
            input = test.py
            prereq = foam_bc_diffusion_flux_pp/run
        []
        [run_diffusivity_cv]
            type = RunApp
            input = main.i
            cli_args = "FoamBCs/T_flux/diffusivity='Cv' Postprocessors/T_flux/expression='t'"
            prereq = foam_bc_diffusion_flux_pp/verify
        []
        [verify_diffusivity_cv]
            type = PythonUnitTest
            input = test.py
            prereq = foam_bc_diffusion_flux_pp/run_diffusivity_cv
        []
    []
[]
