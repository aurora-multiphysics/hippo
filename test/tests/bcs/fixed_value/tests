[Tests]
    [foam_bc_action_test]
        [setup]
            type = RunCommand
            command = 'bash -c "foamCleanCase -case foam && blockMesh -case foam && decomposePar -force -case foam"'
        []
        [run]
            type = RunApp
            input = main.i
            prereq = foam_bc_action_test/setup
            allow_warnings = true
        []
        [verify]
            type = PythonUnitTest
            input = test.py
            prereq = foam_bc_action_test/run
        []
        [run_parallel]
            type = RunApp
            input = main.i
            min_parallel=4
            max_parallel=4
            prereq = foam_bc_action_test/setup
            allow_warnings = true
        []
        [prep_verify]
            type = RunCommand
            command = 'bash -c "reconstructPar -case foam"'
            prereq = foam_bc_action_test/run_parallel
        []
        [verify_parallel]
            type = PythonUnitTest
            input = test.py
            prereq = foam_bc_action_test/prep_verify
        []
    []
[]
