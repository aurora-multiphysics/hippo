[Tests]
    [run_reference]
        [setup]
            type = RunCommand
            command = 'bash -c "cd foam && ./Allclean && blockMesh && decomposePar"'
        []
        [run]
            type = RunApp
            input = main_restep.i
            min_parallel=2
            max_parallel=2
            prereq = run_reference/setup
            allow_warnings = true
            cli_args="Problem/type=FEProblem Executioner/TimeStepper/type=ConstantDT Executioner/TimeStepper/dt=0.0003125 -w"
        []
        [copy]
            type = RunCommand
            command = 'bash -c "reconstructPar -case foam && mkdir -p gold && cp -r foam/* gold/ && cp main_out.e gold/"'
        []
    []
    [restep]
        [setup]
            type = RunCommand
            command = 'bash -c "foamCleanCase -case foam && blockMesh -case foam && decomposePar -case foam"'
        []
        [run]
            type = Exodiff
            input = main_restep.i
            exodiff = main_out.e
            min_parallel = 2
            max_parallel = 2
            prereq = 'restep/setup'
            allow_test_objects=true
        []
        [prep_verify]
            type = RunCommand
            command = 'bash -c "reconstructPar -case foam"'
            prereq = restep/run
        []
        [verify]
            type = PythonUnitTest
            input = test.py
            prereq = restep/setup
        []
        [clean]
            type = RunCommand
            command = 'bash -c "rm -rf gold"'
            prereq = run_reference/copy
        []
    []
[]
