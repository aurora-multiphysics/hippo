[Tests]
    [postprocessor_test]
        [setup]
            type = RunCommand
            command = 'bash -c "foamCleanCase -case foam && blockMesh -case foam && decomposePar -case foam"'
        []
        [check_csv]
            type = CSVDiff
            input = main.i
            prereq = postprocessor_test/setup
            csvdiff = main_out.csv
            allow_warnings = true
        []
        [check_csv_parallel]
            type = CSVDiff
            input = main.i
            prereq = postprocessor_test/setup
            csvdiff = main_out.csv
            allow_warnings = true
            min_parallel = 2
            max_parallel = 2
        []
    []
[]
