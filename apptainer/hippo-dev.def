Bootstrap: oras
From: ghcr.io/idaholab/apptainer/moose-dev-mpich-x86_64:2026.02.20

%arguments
    MOOSE_JOBS=4
    OPENFOAM_JOBS=4

%files
    ./scripts/install-openfoam.sh /opt/hippo/scripts/install-openfoam.sh
    ./scripts/openfoam.patch /opt/hippo/scripts/openfoam.patch
    ./requirements.test.txt /opt/hippo/
    ./scripts/openfoam-prefs.sh /root/.OpenFOAM/prefs.sh

%post
    dnf --enablerepo=devel install -y \
        findutils \
        flex \
        git \
        glibc-devel \
        glibc-headers \
        libgfortran \
        libgomp \
        libtirpc-devel \
        make \
        wget \
        zlib-devel

    wget https://dl.fedoraproject.org/pub/epel/8/Everything/x86_64/Packages/g/glpk-4.65-4.el8.x86_64.rpm
    wget https://dl.fedoraproject.org/pub/epel/8/Everything/x86_64/Packages/g/glpk-devel-4.65-4.el8.x86_64.rpm
    dnf install -y \
        ./glpk-4.65-4.el8.x86_64.rpm \
        ./glpk-devel-4.65-4.el8.x86_64.rpm

    rm glpk-*
    dnf clean all

    # MOOSE
    export MOOSE_DIR=/opt/moose
    export LIBMESH_DIR=/opt/libmesh
    export PETSC_DIR=/opt/petsc
    export WASP_DIR=/opt/wasp
    export VTKINCLUDE_DIR=/opt/vtk/include/vtk-9.3
    export VTKLIB_DIR=/opt/vtk/lib

    # MPI
    export MPI_ROOT=/opt/mpich
    export MPI_ARCH_INC="-I/opt/mpich/include"
    export MPI_ARCH_LIBS="-L/opt/mpich/lib -lmpi"
    export LD_LIBRARY_PATH="${MPI_ROOT}/lib:${LD_LIBRARY_PATH}"
    export PATH="${MPI_ROOT}/bin:${PATH}"
    # Compiler
    export CC=/opt/mpich/bin/mpicc
    export CXX=/opt/mpich/bin/mpicxx
    export F77=/opt/mpich/bin/mpif77
    export F90=/opt/mpich/bin/mpif90
    export PATH="/opt/rh/gcc-toolset-12/root/usr/bin:${PATH}"
    export CPLUS_INCLUDE_PATH="/opt/rh/gcc-toolset-12/root/usr/include/c++/12:${CPLUS_INCLUDE_PATH}"
    export LD_LIBRARY_PATH="/opt/rh/gcc-toolset-12/root/usr/lib64:/opt/rh/gcc-toolset-12/root/usr/lib:${LD_LIBRARY_PATH}"
    # Conda
    export CONDA_PREFIX=/opt/miniforge3
    export CONDA_SHLVL=1
    export CONDA_EXE=/opt/miniforge3/bin/conda
    export CONDA_PYTHON_EXE=/opt/miniforge3/bin/python
    export CONDA_DEFAULT_export=base
    export PATH="${CONDA_PREFIX}/bin:/opt/miniforge3/condabin:${PATH}"
    export CPLUS_INCLUDE_PATH="/opt/miniforge3/include/python3.12:${CPLUS_INCLUDE_PATH}"

    ln -s /opt/miniforge3/bin/python3-config /opt/miniforge3/bin/python-config

    git clone --depth=1 --branch release \
                 https://github.com/idaholab/moose.git "${MOOSE_DIR}"

    make -C "${MOOSE_DIR}/modules/heat_transfer" -j {{ MOOSE_JOBS }}


    ln -s "${MPI_ROOT}/lib" "${MPI_ROOT}/lib64"

    cd /opt/hippo
    ./scripts/install-openfoam.sh -o /opt/openfoam -s -j {{ OPENFOAM_JOBS }} -q

    conda install pre-commit --file /opt/hippo/requirements.test.txt -S --yes --quiet

    git -C "${MOOSE_DIR}" submodule update --init large_media

    groupadd -g 1001 --non-unique hippo-test-user
    useradd -u 1001 -g 1001 --shell /bin/bash --create-home hippo-test-user
    chown -R hippo-test-user:hippo-test-user /opt/moose

%environment
    . /opt/openfoam/OpenFOAM-12/etc/bashrc
    unset FOAM_SIGFPE
    export MOOSE_DIR=/opt/moose

%runscript
    #!/bin/bash
    exec /opt/hippo/hippo-opt $@
