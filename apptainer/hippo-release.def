Bootstrap: oras
From: quay.io/ukaea/hippo:dev-148e4238a4

%arguments
    GIT_SHA=0
    MOOSE_JOBS=4
%post
    cd /opt/hippo
    rm -rf *
    git clone https://github.com/aurora-multiphysics/hippo.git .
    git checkout {{ GIT_SHA }}
    git config --global --add safe.directory /opt/moose

    . /opt/openfoam/OpenFOAM-12/etc/bashrc || true

    make -j {{ MOOSE_JOBS }}
%test
    cd /opt/hippo
    ./run_tests
