Bootstrap: oras
From: quay.io/ukaea/hippo:dev-5f05dea21e

%files
    . /opt/hippo/

%arguments
    MOOSE_JOBS=4

%post
    source  /opt/openfoam/OpenFOAM-12/etc/bashrc || true
    cd /opt/hippo/

    git clean -f
    git config --global --add safe.directory /opt/moose

    make clean

    make -j {{ MOOSE_JOBS }} all METHOD=opt
    make -j {{ MOOSE_JOBS }} all METHOD=dbg

%test
    cd /opt/hippo
    ./run_tests
