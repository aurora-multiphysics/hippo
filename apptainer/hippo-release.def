Bootstrap: oras
From: quay.io/ukaea/hippo:dev-febd5a9693

%files
    .git /opt/hippo/.git
    doc /opt/hippo/doc
    examples /opt/hippo/examples
    include /opt/hippo/include
    scripts /opt/hippo/scripts
    src /opt/hippo/src
    test /opt/hippo/test
    unit /opt/hippo/unit
    Makefile /opt/hippo/Makefile
    hippo.mk /opt/hippo/hippo.mk
    run_tests /opt/hippo/run_tests
    testroot /opt/hippo/testroot

%arguments
    MOOSE_JOBS=4

%post
    export MPI_ROOT=/opt/openmpi
    export MOOSE_DIR=/opt/moose

    source /opt/openfoam/OpenFOAM-12/etc/bashrc || true
    export FOAM_USER_LIBBIN=/root/OpenFOAM-12/lib
    export FOAM_USER_APPBIN=/root/OpenFOAM-12/bin

    cd /opt/hippo/
    # Restore git repository to pristine state - useful for building locally
    git clean -d -f -x
    git config --global --add safe.directory /opt/moose

    make -j {{ MOOSE_JOBS }} all METHOD=opt
    make -j {{ MOOSE_JOBS }} all METHOD=dbg

    rm -rf .git

%environment
    export MPI_ROOT=/opt/openmpi
    export MOOSE_DIR=/opt/moose
    if [ -f $HOME/.OpenFOAM/prefs.sh ]; then
        echo "WARNING: Potential clash of OpenFOAM environment variables from $HOME/.OpenFOAM/prefs.sh. Consider removing!"
    fi

    source /opt/openfoam/OpenFOAM-12/etc/bashrc
    export LD_LIBRARY_PATH=$LD_LIBRARY_PATH:/root/OpenFOAM-12/lib/
    export PATH=$PATH:/root/OpenFOAM-12/bin/
    unset FOAM_SIGFPE
    export PMIX_MCA_gds=hash


%runscript
    #!/bin/bash

    exec /opt/hippo/hippo-opt $@
